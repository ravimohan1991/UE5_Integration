#ifndef SOARVERSION_H
#define SOARVERSION_H

#define _soar_xstr(s) _soar_str(s)
#define _soar_str(s) #s

/*
CMake builds: This file is generated by configure_file() from soarversion.h.in.
The version is set in the root CMakeLists.txt project(VERSION x.y.z).

SCons builds: Use the hand-maintained soarversion.h instead.
*/
#define MAJOR_VERSION_NUMBER @soar_VERSION_MAJOR@
#define MINOR_VERSION_NUMBER @soar_VERSION_MINOR@
#define MICRO_VERSION_NUMBER @soar_VERSION_PATCH@
#define GREEK_VERSION_NUMBER 0
inline const char* VERSION_STRING()
{
    return _soar_xstr(MAJOR_VERSION_NUMBER) "." _soar_xstr(MINOR_VERSION_NUMBER) "."  _soar_xstr(MICRO_VERSION_NUMBER) _soar_xstr(GREEK_VERSION_NUMBER);
}

#define SML_MAJOR_VERSION_NUMBER @soar_VERSION_MAJOR@
#define SML_MINOR_VERSION_NUMBER @soar_VERSION_MINOR@
#define SML_MICRO_VERSION_NUMBER @soar_VERSION_PATCH@
#define SML_GREEK_VERSION_NUMBER 0
inline const char* SML_VERSION_STRING()
{
    return _soar_xstr(SML_MAJOR_VERSION_NUMBER) "." _soar_xstr(SML_MINOR_VERSION_NUMBER) "."  _soar_xstr(SML_MICRO_VERSION_NUMBER) _soar_xstr(GREEK_VERSION_NUMBER);
}

#endif // SOARVERSION_H
